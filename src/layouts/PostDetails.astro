---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Tag from "../components/Tag.astro";
import Datetime from "../components/Datetime.tsx";
import { render, type CollectionEntry } from "astro:content";
import { slugifyStr } from "../utils/slugify";

export interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { title, author, description, ogImage, pubDatetime, tags } = post.data;

const blog2023Files = import.meta.glob<{ file: string; images: Record<string, { src: string }> }>(
  "/src/content/blog/2023/**/*",
);

async function getAssetsOGImageURL() {
  return new URL(ogImage ? ogImage : `${title}.png`, Astro.url.origin).href;
}

async function getOptimizedOGImageURL() {
  const entries = await Promise.all(
    Object.values(blog2023Files).map(load => load()),
  );
  const match = entries.find(file => file.file?.endsWith(post?.id));
  const images = match?.images;
  const optimizedOGImage = images?.[ogImage ?? ""]?.src;
  return new URL(
    optimizedOGImage ? optimizedOGImage : `${title}.png`,
    Astro.url.origin
  ).href;
}

const { Content } = await render(post);
const ogUrl = ogImage?.startsWith("/assets")
  ? await getAssetsOGImageURL()
  : await getOptimizedOGImageURL();
---

<Layout title={title} author={author} description={description} ogImage={ogUrl}>
  <Header />
  <div class="mx-auto flex w-full max-w-4xl justify-start px-2">
    <button
      class="focus-outline mb-2 mt-8 flex hover:opacity-75"
      onclick="history.back()"
    >
      <svg xmlns="http://www.w3.org/2000/svg"
        ><path
          d="M13.293 6.293 7.586 12l5.707 5.707 1.414-1.414L10.414 12l4.293-4.293z"
        ></path>
      </svg><span>Go back</span>
    </button>
  </div>
  <main id="main-content">
    <h1 class="post-title">{title}</h1>
    {
      pubDatetime && (
        <Datetime datetime={pubDatetime} size="lg" className="my-2" />
      )
    }
    <article id="article" role="article" class="prose mx-auto mt-8 max-w-4xl">
      <Content />
    </article>

    <ul class="tags-container">
      {tags.map(tag => <Tag name={slugifyStr(tag)} />)}
    </ul>
  </main>
  <Footer />
</Layout>

<style>
  @reference "../styles/base.css";
main {
    @apply mx-auto w-full max-w-4xl px-4 pb-12;
  }
  .post-title {
    @apply text-2xl font-semibold text-skin-accent;
  }
  .tags-container {
    @apply my-8;
  }
</style>
